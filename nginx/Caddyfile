# Radar Público — Reverse proxy con TLS automático
# Un solo dominio: frontend en / y API en /api/*
# Variable de entorno:
#   DOMAIN_APP — dominio principal (default: radarpublico.cl)

{$DOMAIN_APP:radarpublico.cl} {
    encode gzip zstd

    # API FastAPI — rutas propias del backend
    handle /api/* {
        reverse_proxy api:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /health {
        reverse_proxy api:8000
    }

    handle /docs {
        reverse_proxy api:8000
    }

    handle /openapi.json {
        reverse_proxy api:8000
    }

    # Assets inmutables de Next.js
    handle /_next/static/* {
        header Cache-Control "public, max-age=31536000, immutable"
        reverse_proxy web:3000
    }

    # Frontend Next.js — todo lo demás
    handle {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            transport http {
                dial_timeout 10s
            }
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    log {
        output stdout
        format console
    }
}
