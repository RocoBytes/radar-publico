# ============================================================
# Radar Público — .gitignore
# ============================================================

# === Variables de entorno (CRÍTICO: nunca commitear) ===
.env
.env.local
.env.*.local
!.env.example

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
build/
develop-eggs/
dist/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.manifest
*.spec
MANIFEST

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Tests y coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linters / formatters
.ruff_cache/

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# === Node.js / Next.js ===
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Builds
.next/
out/
build/

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env (Next.js los lee aparte, mejor ignorarlos completos)
.env.development.local
.env.production.local
.env.test.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# === Docker ===
# No ignorar Dockerfile ni docker-compose.yml
# Sí ignorar overrides locales
docker-compose.override.yml

# === Editores e IDEs ===
.vscode/
!.vscode/settings.json.example
!.vscode/launch.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.cursor/
.zed/

# === Sistema operativo ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# === Logs ===
logs/
*.log
log/

# === Backups locales ===
backups/
*.sql.gz
*.dump
*.backup

# === Archivos temporales del proyecto ===
tmp/
temp/
.cache/

# === Storage local (uploads en dev) ===
uploads/
storage/

# === Secrets y certificados ===
*.pem
*.key
*.crt
*.p12
secrets/

# === Celery ===
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# === Alembic versions: SÍ se commitean ===
# (no agregar nada aquí)

# === Datos de desarrollo / fixtures grandes ===
# Si descargas dumps de Datos Abiertos para backfill, evitar commitear
data/raw/
data/*.csv
data/*.json
!data/.gitkeep
