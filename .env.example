# Radar Público — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA commitear el .env real al repositorio

# ============================================================
# Base de datos
# ============================================================
POSTGRES_PASSWORD=cambiar_por_password_seguro

# ============================================================
# Seguridad (CRÍTICO — generar valores nuevos para producción)
# ============================================================
# JWT_SECRET: cualquier string aleatorio largo. Genera con:
#   openssl rand -hex 32
JWT_SECRET=cambiar_jwt_secret_min_32_caracteres_aleatorios

# ENCRYPTION_KEY: exactamente 32 bytes para AES-256. Genera con:
#   openssl rand -base64 32 | head -c 32
ENCRYPTION_KEY=cambiar_encryption_key_32_bytes_

# ============================================================
# IA (Anthropic + Voyage)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
LLM_PROVIDER=anthropic
LLM_MODEL_REASONING=claude-opus-4-7
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# ============================================================
# Notificaciones
# ============================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alertas@radarpublico.cl
WHATSAPP_PROVIDER_API_KEY=

# ============================================================
# Storage (Cloudflare R2)
# ============================================================
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=radar-publico-dev
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ============================================================
# Observabilidad (opcional en dev, recomendado en prod)
# ============================================================
SENTRY_DSN=

# ============================================================
# Flower (UI de Celery, solo dev)
# ============================================================
FLOWER_AUTH=admin:cambiar_password

# ============================================================
# Producción (Digital Ocean) — solo cuando despliegues
# ============================================================
DOMAIN_APP=radarpublico.cl
DOMAIN_API=api.radarpublico.cl
NEXT_PUBLIC_API_URL=https://api.radarpublico.cl
NEXT_PUBLIC_APP_URL=https://radarpublico.cl
CORS_ORIGINS=https://radarpublico.cl
